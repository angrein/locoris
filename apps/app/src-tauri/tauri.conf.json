{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Locoris",
  "version": "1.0.11",
  "identifier": "com.locoris.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Locoris",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "center": true,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Orbital knowledge map",
    "longDescription": "Locoris is an orbital knowledge map for local-first projects, notes, canvases, and sync.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGQUMyQjMxRTc5MTc2QjcKUldTM2RwSG5NU3VzejRuRytHekZmaFEyK29KZ1BiNEhYT3Zqd0VpLzJ1S2JzczlKK2lLdk42RXQK",
      "endpoints": [
        "https://github.com/angrein/locoris/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
